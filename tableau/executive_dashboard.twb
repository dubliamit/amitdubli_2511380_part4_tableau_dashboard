      <aliases enabled='yes' />
      <column caption='Profit Margin' datatype='real' name='[Calculation_1258133020667904]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='SUM([profit]) / SUM([sales]) *100' />
      </column>
      <column caption='Cost' datatype='real' name='[Calculation_1258133020938241]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='[sales] - [profit]' />
      </column>
      <column caption='Average Order Value (AOV)' datatype='real' name='[Calculation_1258133021757442]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='SUM([sales]) / COUNTD([customer_id])' />
      </column>
      <column caption='Return Rate' datatype='real' name='[Calculation_1258133022142467]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='(SUM([return_flag])/COUNT([customer_id]))*100' />
      </column>
      <column caption='Shipping Delay Bucket' datatype='string' name='[Calculation_1258133023805444]' role='dimension' type='nominal'>
        <calculation class='tableau' formula='IF DATEDIFF(&apos;day&apos;, [order_date], [ship_date]) &lt;= 2 THEN&#13;&#10;    &quot;0–2 Days&quot;&#13;&#10;ELSEIF DATEDIFF(&apos;day&apos;, [order_date], [ship_date]) &lt;= 5 THEN&#13;&#10;    &quot;3–5 Days&quot;&#13;&#10;ELSEIF DATEDIFF(&apos;day&apos;, [order_date], [ship_date]) &lt;= 7 THEN&#13;&#10;    &quot;6–7 Days&quot;&#13;&#10;ELSE&#13;&#10;    &quot;8+ Days&quot;&#13;&#10;END' />
      </column>
